{
  "metadata": [
    {
      "src": [
        {
          "files": ["src/Sigstore/Sigstore.csproj"],
          "src": ".."
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "net10.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml", "api/index.md"]
      },
      {
        "files": ["articles/**.md", "articles/**.yml", "*.md", "toc.yml"]
      }
    ],
    "resource": [
      {
        "files": ["images/**", "logo.svg"]
      }
    ],
    "dest": "_site",
    "globalMetadata": {
      "_appTitle": "sigstore-dotnet",
      "_appName": "sigstore-dotnet",
      "_appLogoPath": "logo.svg",
      "_appFooter": "sigstore-dotnet — <a href=\"https://github.com/ozimakov/sigstore-dotnet/blob/main/LICENSE\">Apache 2.0 License</a> — Built with <a href=\"https://dotnet.github.io/docfx\">DocFX</a>",
      "_enableSearch": true,
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/ozimakov/sigstore-dotnet",
        "branch": "main"
      }
    },
    "template": ["default", "modern"]
  }
}
