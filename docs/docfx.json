{
  "metadata": [
    {
      "src": [
        {
          "files": ["src/Sigstore/Sigstore.csproj"],
          "src": ".."
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "net10.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml", "api/index.md"]
      },
      {
        "files": ["articles/**.md", "*.md", "toc.yml"]
      }
    ],
    "resource": [
      {
        "files": ["images/**"]
      }
    ],
    "dest": "_site",
    "globalMetadata": {
      "_appTitle": "sigstore-dotnet",
      "_appFooter": "sigstore-dotnet — Apache 2.0 License",
      "_enableSearch": true
    },
    "template": ["default", "modern"]
  }
}
